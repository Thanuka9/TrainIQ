# TrainIQ production environment — copy to .env and fill all secrets.
# Generate SECRET_KEY: python scripts/production_preflight.py --generate-secret
# Validate before deploy: python scripts/production_preflight.py

# ── Core (required) ────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=
DATABASE_URL=postgresql://user:pass@postgres:5432/collective_rcm
REDIS_URI=redis://redis:6379/0
MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=collective_rcm

# ── CEO bootstrap (required) ───────────────────────────────────
TRAINIQ_CEO_EMAIL=ceo@yourcompany.com
TRAINIQ_CEO_DEFAULT_PASSWORD=

# ── Security ───────────────────────────────────────────────────
SESSION_COOKIE_SECURE=true
SCHEMA_GUARDS_FROZEN=true
DB_BOOTSTRAP_ON_STARTUP=false
PLATFORM_STAFF_REQUIRE_2FA=true

# ── Service split ──────────────────────────────────────────────
# web worker:
SERVICE_MODE=web
RUN_SCHEDULER=false
EVENT_BUS_CONSUMER=false
OPS_WORKER_MODE=false
# ops-worker (separate process):
# SERVICE_MODE=full
# RUN_SCHEDULER=true
# OPS_WORKER_MODE=true
# EVENT_BUS_CONSUMER=true
# EVENT_BUS_ENABLED=true

EVENT_BUS_ENABLED=true
EVENT_BUS_STREAM=trainiq:ops:events
EVENT_BUS_GROUP=trainiq-ops-workers

# ── Email (required for 2FA, trials, invites) ──────────────────
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@trainiq.com

# ── Stripe (billing) ─────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── Observability ──────────────────────────────────────────────
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_METRICS_TOKEN=
LOG_JSON=true

# ── Gunicorn (optional tuning) ─────────────────────────────────
WEB_CONCURRENCY=4
GUNICORN_BIND=0.0.0.0:5000
GUNICORN_TIMEOUT=120

# ── Optional: read replicas, S3 AI cache, ops webhooks ─────────
DATABASE_READ_REPLICA_URL=
MONGO_READ_URI=
MONGO_READ_PREFERENCE=secondaryPreferred
AI_CACHE_S3_BUCKET=
AI_CACHE_S3_PREFIX=trainiq/ai-cache
AWS_REGION=us-east-1
OPS_AUTO_REMEDIATE_SAFE=false
PLATFORM_OPS_ALERT_WEBHOOK=

# ── Docker Compose prod stack (docker-compose.prod.yml) ────────
POSTGRES_USER=trainiq
POSTGRES_PASSWORD=
POSTGRES_DB=collective_rcm
WEB_PORT=5000
PLATFORM_PORT=5001
