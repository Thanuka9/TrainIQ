# ─── Core (required in production) ───────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=postgresql://postgres:password@localhost/collectivercm

# HTTPS / cookies (set SESSION_COOKIE_SECURE=True when serving over HTTPS)
SESSION_COOKIE_SECURE=False

# Optional: Redis for Flask-Limiter (recommended in production)
REDIS_URI=redis://localhost:6379

# Session inactivity timeout (minutes) — server-side AFK logout
SESSION_AFK_MINUTES=75

# Mail (required for 2FA and verification emails in production)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@example.com

# MongoDB
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=collective_rcm

# ─── TrainIQ Local AI (Ollama / Gemma 4) ─────────────────────────────────────
OLLAMA_BASE=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_TIMEOUT=180
OLLAMA_CONTEXT_CHARS=12000
AI_CACHE_TTL=604800
AI_RATE_LIMIT_HOUR=20
AI_RATE_LIMIT_MINUTE=5
AI_VISION_MIN_CHARS=120
