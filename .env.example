# ── Flask ──────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
FLASK_ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/collective_rcm

# ── MongoDB (optional — file uploads disabled if unavailable) ───
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=collective_rcm

# ── Redis (sessions / rate limiting) ────────────────────────────
REDIS_URI=redis://localhost:6379/0

# ── TrainIQ Platform CEO ───────────────────────────────────────
TRAINIQ_CEO_EMAIL=thanuka.ellepola@gmail.com
TRAINIQ_CEO_DEFAULT_PASSWORD=          # REQUIRED in production
TRAINIQ_PLATFORM_OFFICE_KEY=TRAINIQ
TRAINIQ_WEBSITE_URL=https://trainiq.com
TRAINIQ_STAFF_DOMAINS=trainiq.com
TRAINIQ_STAFF_EMAILS=                  # optional comma-separated staff emails (CEO always included)

# ── Legal / User Agreement ─────────────────────────────────────
TRAINIQ_AGREEMENT_VERSION=2026.4
TRAINIQ_AGREEMENT_EFFECTIVE_DATE=June 15, 2026
TRAINIQ_LEGAL_ENTITY=Veyra Labs
TRAINIQ_OWNER_NAME=Thanuka Ellepola
TRAINIQ_OWNER_ORGANIZATION=Veyra Labs
TRAINIQ_OWNER_URL=https://thanukaellepola.careers/en
TRAINIQ_LEGAL_EMAIL=legal@veyralabs.com
TRAINIQ_SUPPORT_EMAIL=support@trainiq.com
TRAINIQ_GOVERNING_LAW=the State of Delaware, United States of America
TRAINIQ_TRIAL_DAYS=30

# ── Stripe (optional — manual plan upgrade if unset) ───────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
# Optional stable Price IDs (preferred over ad-hoc price_data in Checkout)
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_YEARLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_YEARLY=

# ── Security (Phase A) ─────────────────────────────────────────
PLATFORM_STAFF_REQUIRE_2FA=true
TRAINIQ_TOTP_ISSUER=TrainIQ
# Optional OIDC SSO for platform tenant staff (applied on CEO bootstrap)
PLATFORM_OIDC_PROVIDER=oidc
PLATFORM_OIDC_CLIENT_ID=
PLATFORM_OIDC_CLIENT_SECRET=
PLATFORM_OIDC_ISSUER_URL=
PLATFORM_OIDC_TENANT_DOMAIN=

# ── Email ──────────────────────────────────────────────────────
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@trainiq.com

# ── Ollama / LearnIQ (local only — no paid cloud API) ───────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e4b

# ── Debug ──────────────────────────────────────────────────────
ALLOW_DEBUG_EXAM=0

# ── Platform operations (CEO /platform/operations — Postgres, Mongo, AI) ───
DB_MONITOR_ENABLED=true
DB_MONITOR_INTERVAL_HOURS=6
DB_OPTIMIZER_AUTO_APPLY=false
# Use CREATE INDEX CONCURRENTLY when applying safe indexes (recommended for production)
DB_INDEX_USE_CONCURRENTLY=true

# Platform support mode auto-exits after N hours (re-enter from Command Center)
PLATFORM_SUPPORT_TTL_HOURS=2
# Optional comma-separated IPs/CIDRs allowed to access /platform/* (empty = no restriction)
TRAINIQ_PLATFORM_IP_ALLOWLIST=
# Write elevation inside support mode (admin/CEO with tenants.manage)
PLATFORM_SUPPORT_WRITE_TTL_MINUTES=60
PLATFORM_TENANT_DOMAIN_CACHE_SECONDS=120

# ── Metrics / probes (Phase 2) ────────────────────────────────
OPS_PROBE_MIN_INTERVAL_MINUTES=15
OPS_AGENTS_DELAY_AFTER_MONITOR_MINUTES=5
OPS_AGENTS_LIVE_PROBE=false
OPS_AGENTS_LIVE_MONGO_PROBE=false
DB_SNAPSHOT_RETENTION_DAYS=90
DB_SNAPSHOT_RETENTION_ENABLED=true
DB_SNAPSHOT_MAX_COUNT=500
DB_METRIC_SAMPLE_RETENTION_DAYS=365

# ── Schema / maintenance (Phase 3) ────────────────────────────
DB_BOOTSTRAP_ON_STARTUP=false
SCHEMA_GUARDS_ENABLED=true
SCHEMA_GUARDS_FROZEN=true
PLATFORM_PEAK_GUARD_ENABLED=true
PLATFORM_PEAK_TZ=UTC
PLATFORM_PEAK_HOURS=9-17

# ── Scheduler / ops worker (production) ───────────────────────
# Web workers: RUN_SCHEDULER=false  |  Dedicated worker: RUN_SCHEDULER=true
RUN_SCHEDULER=false
OPS_WORKER_MODE=false
OPS_CACHE_USE_REDIS=true
OPS_METRICS_CACHE_SECONDS=15
PLATFORM_OPS_ALERT_WEBHOOK=
PLATFORM_OPS_ALERT_EMAIL=true
PLATFORM_OPS_ALERT_COOLDOWN_SECONDS=3600

# ── Service split (large deployment) ───────────────────────────
# full = monolith | web = tenant LMS only | platform = CEO console + support enter
SERVICE_MODE=full
EVENT_BUS_ENABLED=false
EVENT_BUS_CONSUMER=false
EVENT_BUS_STREAM=trainiq:ops:events
EVENT_BUS_GROUP=trainiq-ops-workers

# ── Read replicas (optional) ───────────────────────────────────
DATABASE_READ_REPLICA_URL=
MONGO_READ_URI=
MONGO_READ_PREFERENCE=primary

# ── AI cache S3 backend (optional — disk fallback) ─────────────
AI_CACHE_S3_BUCKET=
AI_CACHE_S3_PREFIX=trainiq/ai-cache
AWS_REGION=us-east-1

# ── Safe auto-remediation after health scans ───────────────────
OPS_AUTO_REMEDIATE_SAFE=false

# ── Observability (Phase C) ───────────────────────────────────
PROMETHEUS_METRICS_ENABLED=false
PROMETHEUS_METRICS_TOKEN=
LOG_JSON=false
GRAFANA_ADMIN_PASSWORD=admin

MONGO_TENANT_DB_PREFIX=trainiq_t
AI_CACHE_TTL=604800
TENANT_STORAGE_CACHE_SECONDS=60
# Capacity tuning (production scale)
OPS_PG_SEQ_SCAN_RATIO_WARN=0.85
OPS_PG_SLOW_QUERY_MS=750
OPS_PG_CACHE_HIT_RATIO_WARN=0.95
OPS_PG_DEAD_TUPLES_WARN=50000
OPS_MONGO_PROVISION_WORKERS=8
OPS_MONGO_STORAGE_WARN_MB=4096
OPS_AI_CACHE_MAX_MB=512
OPS_AI_LATENCY_WARN_MS=8000
OPS_AI_BENCHMARK_ENABLED=true
OPS_AGENTS_ENABLED=true
OPS_AGENTS_INTERVAL_HOURS=2
OPS_AGENTS_CACHE_TTL=1800
OPS_AGENTS_USE_AI=true

# ── CEO full maintenance — optional app restart after one-click run ───
# Option A: webhook (Logic App, GitHub workflow dispatch, etc.)
PLATFORM_RESTART_WEBHOOK_URL=
# Option B: Azure App Service Kudu (WEBSITE_SITE_NAME is auto-set on Azure)
AZURE_WEBSITE_PUBLISH_USER=
AZURE_WEBSITE_PUBLISH_PASSWORD=
